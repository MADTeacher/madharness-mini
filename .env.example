# Скопируйте этот файл в .env и задайте URL роутера, model slug и токен.
# Эти значения имеют приоритет над .madharness-mini/config.json.

MADHARNESS_MINI_BASE_URL=https://openrouter.ai/api/v1
MADHARNESS_MINI_MODEL=deepseek/deepseek-v4-flash
MADHARNESS_MINI_API_KEY=your-token-here
MADHARNESS_MINI_SUPPORTS_IMAGE_INPUT=false
MADHARNESS_MINI_MAX_IMAGE_BYTES=5000000
MADHARNESS_MINI_IMAGE_DETAIL=auto
